.title-row { display: flex; justify-content: space-between; gap: 8rpx; }
.title { font-size: 34rpx; font-weight: 700; max-width: 75%; }
.mini { font-size: 24rpx; line-height: 1.5; padding: 0 20rpx; }
.orig { margin-top: 10rpx; color: #4f5f7a; }
.meta { margin-top: 10rpx; color: #8892a6; font-size: 24rpx; }
.illustration { width: 100%; height: 360rpx; border-radius: 16rpx; }
.placeholder { background: #f5f8ff; border-radius: 16rpx; padding: 80rpx 20rpx; text-align: center; color: #8d95a6; }
.read-actions { display: flex; gap: 12rpx; margin-top: 16rpx; }
