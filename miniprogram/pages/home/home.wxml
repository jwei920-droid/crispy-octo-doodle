<view class="container">
  <view class="card welcome">
    <view class="title">今天她又问了什么？</view>
    <text class="desc">把孩子的“为什么”快速记下来。</text>
  </view>

  <view class="card input-box">
    <view class="section-title">快速记录</view>
    <view class="actions">
      <button class="secondary-btn" bindtap="onVoicePlaceholder">语音记录</button>
      <button class="secondary-btn" bindtap="onImagePlaceholder">图片记录</button>
    </view>
    <input placeholder="输入孩子原话，例如：为什么会下雨？" value="{{questionInput}}" bindinput="onInput" />
    <button class="primary-btn" bindtap="onSubmitText">提交问题</button>
  </view>

  <view class="card stat">
    <view class="section-title">今日统计</view>
    <text>今天记录了 {{todayCount}} 个问题</text>
  </view>

  <view class="shortcut">
    <button class="secondary-btn" bindtap="onOpenHistory">历史页</button>
    <button class="secondary-btn" bindtap="onOpenWeekly">周报页</button>
  </view>

  <view class="section-title">最近问题</view>
  <loading-state wx:if="{{loading}}" />
  <view wx:elif="{{error}}" class="error" bindtap="loadRecent">{{error}}</view>
  <empty-state wx:elif="{{recentItems.length === 0}}" text="把今天第一个“为什么”记下来吧" />
  <block wx:else>
    <question-card wx:for="{{recentItems}}" wx:key="questionId" item="{{item}}" bind:cardtap="onCardTap" bind:favorite="onCardFavorite" />
  </block>
</view>
